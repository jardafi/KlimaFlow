    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^3.1.8",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/vercel": "^7.8.2",
    "@keystatic/astro": "^5.0.3",
    "@keystatic/core": "^0.5.38",
    "astro": "^4.16.18"
  }
}
